# Environment Configuration
# Copy to .env and fill in your values

# LLM Gateway — Anthropic 兼容接口 (mimo-v2.5-pro)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_API_BASE=https://your-anthropic-compatible-endpoint/v1
LLM_PRIMARY_MODEL=anthropic/mimo-v2.5
LLM_FALLBACK_MODEL=anthropic/mimo-v2.5
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Vector Store
CHROMA_HOST=localhost
CHROMA_PORT=8000
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Safety
ENABLE_INPUT_FILTER=true
ENABLE_OUTPUT_FILTER=true
SANDBOX_ENABLED=true
RATE_LIMIT_RPM=60

# Observability
LOG_LEVEL=INFO
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
TRACE_SAMPLE_RATE=1.0

# API Server
API_HOST=0.0.0.0
API_PORT=8080
